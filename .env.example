# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase / Railway connection pooling URL (used by Prisma in serverless)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true&connection_limit=1"
# Direct connection URL (used for migrations, bypasses PgBouncer)
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"   # openssl rand -base64 32

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-redis-id.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"
