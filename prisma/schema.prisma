// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  MEMBER
  SUPER_ADMIN
}

enum DietaryType {
  VEG
  NON_VEG
  BOTH
}

enum SpiceTolerance {
  MILD
  MEDIUM
  HOT
}

enum HealthGoal {
  BALANCED
  WEIGHT_LOSS
  HIGH_PROTEIN
}

// ─── App Models ──────────────────────────────────────────────────────────────

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  passwordHash  String?                              // renamed from password
  avatarUrl     String?                              // renamed from image
  emailVerified DateTime?

  role           UserRole       @default(MEMBER)
  dietaryType    DietaryType    @default(BOTH)
  spiceTolerance SpiceTolerance @default(MEDIUM)
  healthGoal     HealthGoal     @default(BALANCED)
  onboardedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accounts Account[]
  familiesCreated FamilyGroup[]  @relation("FamilyCreator")
  familyMemberships FamilyMember[]
  mealLogs MealLog[]
}

// ─── Family Enums ─────────────────────────────────────────────────────────────

// Role within a specific family — separate from app-level UserRole
enum FamilyRole {
  MEMBER // can view feed, accept/reject broadcasts
  ADMIN  // can broadcast meals, manage members, invite
}

// ─── Family Models ────────────────────────────────────────────────────────────

model FamilyGroup {
  id         String   @id @default(uuid())
  name       String                          // family display name e.g. "The Mahmood Family"
  inviteCode String   @unique                // 8-char code others use to join e.g. "GHK-7X2P"
  createdBy  String                          // userId of whoever created this group

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?                       // soft delete — archived families stay in DB

  // Relations
  creator    User            @relation("FamilyCreator", fields: [createdBy], references: [id])
  members    FamilyMember[]  // all memberships in this family
}

model FamilyMember {
  id       String     @id @default(uuid())
  familyId String                            // which family
  userId   String                            // which user
  role     FamilyRole @default(MEMBER)       // their role in THIS family

  joinedAt  DateTime  @default(now())        // when they joined

  // Relations
  family   FamilyGroup @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One user can only appear once per family — no duplicates
  @@unique([familyId, userId])

  // Index for fast lookup — "find all families this user is in"
  @@index([userId])
}

// ─── Menu Catalog Enums ───────────────────────────────────────────────────────

enum BaseType {
  RICE_BASED
  ROTI_BASED
  STANDALONE
  BOTH
}

enum DishDietaryType {
  VEG
  NON_VEG
  VEGAN
}

enum ProteinType {
  CHICKEN
  MUTTON
  BEEF
  FISH
  LENTIL
  PANEER
  EGG
  NONE
}

enum SpiceLevel {
  MILD
  MEDIUM
  HOT
  EXTRA_HOT
}

enum MealTime {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

// ─── Menu Catalog Models ──────────────────────────────────────────────────────

model Dish {
  id              String          @id @default(uuid())
  name            String
  nameUrdu        String?
  description     String?
  imageUrl        String?

  baseType        BaseType        @default(STANDALONE)
  dietaryType     DishDietaryType @default(NON_VEG)
  proteinType     ProteinType     @default(NONE)
  spiceLevel      SpiceLevel      @default(MEDIUM)
  region          String?

  isQuick         Boolean         @default(false)
  isHealthy       Boolean         @default(false)
  isFestive       Boolean         @default(false)

  prepTimeMinutes Int?
  mealTimes       MealTime[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  tags      DishTag[]
  nutrition DishNutrition?
  recipe    DishRecipe?
  mealLogs MealLog[]

  // Indexes for fast filter queries
  @@index([baseType, dietaryType, spiceLevel])
  @@index([isQuick, isHealthy])
  @@index([region])
}

model DishTag {
  id     String @id @default(uuid())
  dishId String
  tag    String

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([dishId, tag])
  @@index([tag])
}

model DishNutrition {
  id     String @id @default(uuid())
  dishId String @unique

  servingDescription String?
  calories           Float?
  protein            Float?
  carbohydrates      Float?
  fat                Float?
  fiber              Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)
}

model DishRecipe {
  id     String @id @default(uuid())
  dishId String @unique

  ingredients Json
  steps       Json
  servings    Int  @default(4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)
}



// ─── Meal Logging Models ──────────────────────────────────────────────────────


enum MealLogSource {
  PERSONAL  // user logged this themselves
  FAMILY    // came from a family broadcast
}


model MealLog {
  id             String   @id @default(uuid())
  userId         String                          // who ate this
  dishId         String?                         // nullable — null if custom meal
  customMealName String?                         // filled if dishId is null

  logDate  DateTime                              // the date this meal was eaten
  mealTime MealTime                              // BREAKFAST, LUNCH, DINNER, SNACK
  servings Float    @default(1.0)               // how many servings
  notes    String?                               // optional free text

  source MealLogSource @default(PERSONAL)        // personal or from family broadcast

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  dish Dish? @relation(fields: [dishId], references: [id], onDelete: SetNull)

  // Fast lookup — find all logs for a user on a specific date
  @@index([userId, logDate])
  @@index([logDate])
}


// ─── NextAuth Required Models (do not modify) ────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}